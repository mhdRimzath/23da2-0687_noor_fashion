rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Users Profile Images
    match /users/{userId}/profile_images/{imageId} {
      // Only the specific user can read and upload to their own folder
      allow read: if true; // Or restrict to request.auth != null && request.auth.uid == userId depending on privacy needs
      allow write: if request.auth != null && request.auth.uid == userId
                   // Optional: restrict image types and size
                   && request.resource.contentType.matches('image/.*')
                   && request.resource.size < 5 * 1024 * 1024; // 5MB limit
    }
    
    // General Assets
    match /assets/{allPaths=**} {
      allow read: if true;
      allow write: if false; // Admin only
    }
  }
}
